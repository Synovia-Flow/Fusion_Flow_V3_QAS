# Synovia Flow 3 — DB connection for the blueprint exporter / read-only API service.
# ------------------------------------------------------------------------------
# EASY RENDER UPLOAD:
#   Render service -> Environment -> "Add from .env" -> paste these lines.
#   Set DB_PASSWORD as a SECRET (do not paste the real password into a committed file).
#
# To produce the REAL file from your local .ini (never committed):
#   python liveWeb/tools/make_env.py --print      # writes liveWeb/.env + echoes this block
#
# This .example holds placeholders only. Copy to liveWeb/.env and fill in, or upload
# to Render directly.
# ------------------------------------------------------------------------------

DB_SERVER=your-server.database.windows.net
DB_NAME=Fusion_Flow_V3_QAS
DB_USER=your_sql_user
DB_PASSWORD=__set_as_render_secret__
DB_DRIVER={ODBC Driver 17 for SQL Server}
DB_ENCRYPT=yes
DB_TRUST=no
