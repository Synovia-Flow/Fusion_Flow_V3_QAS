# =====================================================================
# Synovia Flow 3 — ALL environment variables (single file), KEY=VALUE.
# Fill the CHANGE_ME secrets locally. Upload to Render: Environment ->
# "Add from .env" -> paste. (Secrets are CHANGE_ME here because they live
# in the gitignored .ini / tss_credentials.json, not in the repo.)
# =====================================================================

# --- DB connection (READ by liveWeb/app.py + export_blueprint.py) -----
# Tip: `python liveWeb/tools/make_env.py` auto-fills these from the .ini.
DB_SERVER=futureworks-sdi-db.database.windows.net
DB_NAME=Fusion_Flow_V3_QAS
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_DRIVER={ODBC Driver 18 for SQL Server}
DB_ENCRYPT=yes
DB_TRUST=no

# --- Portal / service runtime -----------------------------------------
PORT=8080
PORTAL_ACTIONS_ENABLED=0

# --- Submission (Module 3) --------------------------------------------
SUBMISSION_CLIENT=BKD
SUBMISSION_ENTITY=ENS_HEADER
SUBMISSION_ENV=TST
SUBMISSION_DRY_RUN=1
SUBMISSION_MOVEMENT_KEY=
SUBMISSION_MAX_ROWS=0
SUBMISSION_API_BASE_PATH=/x_fhmrc_tss_api/v1/tss_api
SUBMISSION_JSON_DIR=

# --- Processing (Module 2) --------------------------------------------
PROCESSING_CLIENT=BKD
PROCESSING_ENTITY=ENS_HEADER
PROCESSING_MODE=NEW
PROCESSING_DRY_RUN=0
PROCESSING_TRANSACTION_MODE=latest
PROCESSING_REPROCESS_SCOPE=REJECTED
PROCESSING_MOVEMENT_KEY=

# --- Ingestion (Module 1) ---------------------------------------------
INGESTION_CLIENT=BKD
INGESTION_DRY_RUN=0

# --- Reference data / choice values -----------------------------------
CHOICE_VALUES_CLIENT=BKD
CHOICE_VALUES_ENV=PRD
CHOICE_VALUES_DRY_RUN=0
CHOICE_VALUES_PATH=/x_fhmrc_tss_api/v1/choice_values

# --- API / environment defaults ---------------------------------------
DEFAULT_ENV=TST
API_VERSION_DEFAULT=NEW
API_TIME_ZONE=UTC
API_RATE_LIMIT_SECONDS=0.25
ARRIVAL_MAX_FUTURE_DAYS=14
GMR_READ_WAIT_SECONDS=90
SDI_DEADLINE_DAY=10

# --- TSS environments (base URLs) -------------------------------------
TSS_TST_BASE_URL=https://api.tsstestenv.co.uk/api
TSS_PRD_BASE_URL=https://api.tradersupportservice.co.uk/api

# --- TSS credentials per client/env (usernames + secrets) -------------
TSS_BKD_TST_USERNAME=CHANGE_ME
TSS_BKD_TST_PASSWORD=CHANGE_ME
TSS_BKD_PRD_USERNAME=CHANGE_ME
TSS_BKD_PRD_PASSWORD=CHANGE_ME
TSS_CWD_TST_USERNAME=API.TSS0014334
TSS_CWD_TST_PASSWORD=CHANGE_ME
TSS_PLE_PRD_USERNAME=CHANGE_ME
TSS_PLE_PRD_PASSWORD=CHANGE_ME

# --- Microsoft Graph (email ingestion) --------------------------------
GRAPH_CLIENT_ID=4cbaa4be-f78f-4e82-944a-bf9d4142a12e
GRAPH_TENANT_ID=57afc32b-b3d2-4d9c-b421-4a13db61207c
GRAPH_APP_OBJECT_ID=f46a9a16-ba01-4621-ac68-bc8a0450fd34
GRAPH_TENANT_DOMAIN=NETORG6546503.onmicrosoft.com
GRAPH_AUTHORITY=https://login.microsoftonline.com/
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_PERMISSIONS=Mail.Read,Mail.ReadWrite
GRAPH_MAILBOX=nexus@synoviaflow.cloud
GRAPH_PROCESSED_FOLDER=Fusion_Processed
GRAPH_FORWARDERS=nexus@synoviaintegration.com
GRAPH_CLIENT_SECRET=CHANGE_ME

# --- Output roots (UNC shares) ----------------------------------------
DOCUMENTATION_OUTPUT_ROOT=\\PL-AZ-SDF-PLINT\Fusion_Production\Synovia_Flow_Quality\Documentation_Layer
INTEGRATION_LAYER_ROOT=\\PL-AZ-SDF-PLINT\Fusion_Production\Synovia_Flow_Quality\Integration_Layer
DB_SNAPSHOT_OUTPUT_DIR=\\PL-AZ-SDF-PLINT\Fusion_Production\Synovia_Flow_Quality\Documentation_Layer
