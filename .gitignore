# =====================================================================
# Fusion Flow V3 QAS - .gitignore
# Minimal baseline: Visual Studio / C# solution artifacts.
# Extend this file as the solution grows.
# =====================================================================

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build output
bin/
obj/

# Python artifacts
__pycache__/
*.py[cod]

# Local secrets - keep credentials out of source control. Do not remove.
.env
.env.*
!.env.example

# Live DB connection config (contains a password). Commit the .example template
# instead. Do not remove.
Configuration/Fusion_Flow_QAS.ini
Configuration_Layer/Fusion_Flow_QAS.ini
*.local.ini

# Deploy run logs: verbose/transient. logs/ itself IS committed; only the
# _Ignore subfolder is excluded. Promote a summary up to logs/ to share it.
logs/_Ignore/

# Deploy Queue is a transient staging area; canonical DDL lives in
# Configuration_Layer/SQL. Keep the folder (README) but not staged scripts.
Development/Deploy/Queue/*.sql

# TSS connectivity test credentials (live passwords) - never commit.
Development/Connectivity/tss_credentials.json
Configuration/tss_credentials.json

# TSS response dumps (may contain live declaration data) — analysis output, transient.
Development/json/
