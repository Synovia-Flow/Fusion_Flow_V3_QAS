# =====================================================================
# Fusion Flow V3 QAS - .gitignore
# Minimal baseline: Visual Studio / C# solution artifacts.
# Extend this file as the solution grows.
# =====================================================================

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Build output
bin/
obj/

# Local secrets - keep credentials out of source control. Do not remove.
.env
.env.*
!.env.example

# Deploy run logs: verbose/transient. logs/ itself IS committed; only the
# _Ignore subfolder is excluded. Promote a summary up to logs/ to share it.
logs/_Ignore/
