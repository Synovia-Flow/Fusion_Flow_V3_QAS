# Microsoft Graph values for local/manual execution.
# Keep real values out of GitHub.
# The script accepts either GRAPH.KEY or GRAPH_KEY style names.

GRAPH.TENANT_ID=<GRAPH_TENANT_ID>
GRAPH.CLIENT_ID=<GRAPH_CLIENT_ID>
GRAPH.CLIENT_SECRET=<GRAPH_CLIENT_SECRET>
GRAPH.MAILBOX=nexus@synoviaflow.cloud
GRAPH.FOLDER=inbox
