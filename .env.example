# Microsoft Graph values for local/manual execution.
# Keep real values out of GitHub.
# The script accepts either GRAPH.KEY or GRAPH_KEY style names.

GRAPH.TENANT_ID=<GRAPH_TENANT_ID>
GRAPH.CLIENT_ID=<GRAPH_CLIENT_ID>
GRAPH.CLIENT_SECRET=<GRAPH_CLIENT_SECRET>
GRAPH.MAILBOX=nexus@synoviaflow.cloud
GRAPH.FOLDER=inbox
GRAPH.HISTORIC_START_DATE=2026-05-07
# Optional MVP database ingestion trace.
# Leave disabled/blank for file-only operation.
GRAPH.ENV_CODE=QAS
GRAPH.DB_ENABLED=false
GRAPH.DB_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=<SQL_SERVER>;Database=Fusion_Flow_V3_QAS;Trusted_Connection=yes;TrustServerCertificate=yes
