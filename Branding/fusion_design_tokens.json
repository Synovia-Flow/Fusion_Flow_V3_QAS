{
  "$schema": "https://synovia.digital/fusion/design-tokens.schema.json",
  "name": "Synovia Fusion — Design Tokens",
  "version": "1.0.0",
  "description": "Shared brand + UI tokens for every Fusion solution (portal, reports, decks, Excel exports). Mirrors LiveWeb/app/static/css/style.css :root.",
  "brand": {
    "name": "Synovia Fusion",
    "logos": {
      "product": "FusionLogo.jpg",
      "company": "SynoviaLogoHor.jpg"
    }
  },
  "color": {
    "abyss":   {"hex": "#07152B", "rgb": [7, 21, 43],    "use": "deepest ground / splash / dark hero"},
    "navy":    {"hex": "#0F2A4A", "rgb": [15, 42, 74],   "use": "primary dark / sidebar / nav pill / headers"},
    "navy2":   {"hex": "#143458", "rgb": [20, 52, 88],   "use": "dark surface 2 / nav gradient end"},
    "flow":    {"hex": "#13DAC6", "rgb": [19, 218, 198], "use": "primary brand accent (flow-aqua) / active nav / charts / links"},
    "flow_deep": {"hex": "#0AB6A6", "rgb": [10, 182, 166], "use": "link default / hover / line stroke"},
    "fusion":  {"hex": "#FF7A45", "rgb": [255, 122, 69], "use": "secondary accent (fusion-coral) / 'Powered by Fusion' / attention"},
    "fusion2": {"hex": "#FF9A6B", "rgb": [255, 154, 107],"use": "fusion light / gradient end"},
    "sky":     {"hex": "#3BA0FF", "rgb": [59, 160, 255], "use": "chart secondary / submitted state"},
    "bg":      {"hex": "#EEF3FA", "rgb": [238, 243, 250],"use": "app background (navy-biased neutral)"},
    "surface": {"hex": "#FFFFFF", "rgb": [255, 255, 255],"use": "cards / panels / tiles"},
    "surface2":{"hex": "#F7FAFF", "rgb": [247, 250, 255],"use": "row hover / track / subtle fill"},
    "text":    {"hex": "#132133", "rgb": [19, 33, 51],   "use": "body text (navy-black)"},
    "muted":   {"hex": "#5E7085", "rgb": [94, 112, 133], "use": "secondary text / labels"},
    "border":  {"hex": "#DCE6F2", "rgb": [220, 230, 242],"use": "hairline borders / dividers"},
    "status": {
      "green":  {"hex": "#17B26A", "use": "success / healthy"},
      "amber":  {"hex": "#F79009", "use": "partial / warning"},
      "rose":   {"hex": "#F04438", "use": "failure / error"},
      "violet": {"hex": "#7A5AF8", "use": "info / secondary category"}
    }
  },
  "typography": {
    "family": "'Montserrat', sans-serif",
    "google_fonts": "https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap",
    "excel_fallback": "Segoe UI",
    "weights": {"light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "extrabold": 800},
    "scale_px": {"kpi_value": 28, "page_title": 24, "card_title": 15, "body": 13, "label": 11, "small": 10}
  },
  "layout": {
    "sidebar_width": "220px",
    "radius": {"sm": "4px", "md": "6px", "card": "10px", "tile": "12px", "pill": "12px"},
    "shadow": {"card": "0 1px 3px rgba(11,29,58,0.06)", "tile_hover": "0 6px 18px rgba(11,29,58,0.08)"},
    "transition": "transform 0.14s ease, box-shadow 0.14s ease, border-color 0.14s ease"
  },
  "icons": {"set": "Bootstrap Icons 1.11.3", "css": "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"},
  "css_framework": {"name": "Bootstrap", "version": "5.3.3", "note": "themed via --bs-* overrides to the brand palette"},
  "kpi_accents": {
    "c-sky": "#0EA5E9", "c-green": "#198754", "c-amber": "#F97316",
    "c-rose": "#DC3545", "c-violet": "#7C3AED"
  }
}
